{
  "name": "withyou",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "dev": "npm run build && wrangler pages dev",
    "d1:migrate:local": "wrangler d1 execute withyou --local --file=./schema.sql",
    "d1:migrate:remote": "wrangler d1 execute withyou --remote --file=./schema.sql",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
